{
  "name": "json-contracts",
  "version": "0.1.0",
  "description": "MCP server for JSON contracts, JSON Schema validation, and structured LLM/agent outputs.",
  "type": "module",
  "bin": {
    "json-contracts": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "examples/node-client",
    "json-contracts",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "TRADEMARKS.md",
    "package.json"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "json-contracts",
    "json-schema",
    "llm",
    "ai-agent",
    "structured-output",
    "structured-generation",
    "schema-validation",
    "prompt-contracts",
    "agent-contracts",
    "llm-contracts",
    "data-contracts"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/json-contracts/json-contracts.git"
  },
  "bugs": {
    "url": "https://github.com/json-contracts/json-contracts/issues"
  },
  "homepage": "https://github.com/json-contracts/json-contracts#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "chokidar": "4.0.3",
    "typebox": "1.1.33",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./contract-loader": {
      "types": "./dist/contract-loader.d.ts",
      "import": "./dist/contract-loader.js"
    },
    "./validator": {
      "types": "./dist/validator.d.ts",
      "import": "./dist/validator.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "import": "./dist/prompts.js"
    },
    "./resources": {
      "types": "./dist/resources.d.ts",
      "import": "./dist/resources.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  }
}
