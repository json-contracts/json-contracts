{
  "description": "Convert customer messages into a structured ecommerce return, exchange, refund, or cancellation request.",
  "rules": [
    "Only include order IDs, SKUs, quantities, and item names that the customer explicitly provides.",
    "Use return when the customer wants to send an item back, exchange when they want a different item or size, refund when they only ask for money back, and cancel_order when the item has not shipped yet.",
    "Set urgency to high when the customer mentions a deadline, event date, chargeback, repeated failed attempts, or a very angry escalation.",
    "Use unknown for item condition when it is not stated.",
    "Do not invent policy decisions; this object routes the request, it does not approve it."
  ],
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "intent": {
        "type": "string",
        "enum": [
          "return",
          "exchange",
          "refund",
          "cancel_order",
          "warranty_claim",
          "other"
        ]
      },
      "orderId": {
        "type": "string"
      },
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "sku": {
              "type": "string"
            },
            "quantity": {
              "type": "integer",
              "minimum": 1
            },
            "reason": {
              "type": "string",
              "enum": [
                "damaged",
                "wrong_item",
                "not_as_described",
                "too_small",
                "too_large",
                "changed_mind",
                "late_delivery",
                "defective",
                "other"
              ]
            },
            "condition": {
              "type": "string",
              "enum": [
                "unopened",
                "opened",
                "used",
                "damaged",
                "unknown"
              ]
            }
          },
          "required": [
            "reason",
            "condition"
          ]
        },
        "default": []
      },
      "requestedResolution": {
        "type": "string",
        "enum": [
          "refund",
          "replacement",
          "store_credit",
          "exchange",
          "cancel",
          "other"
        ]
      },
      "urgency": {
        "type": "string",
        "enum": [
          "low",
          "normal",
          "high"
        ]
      },
      "customerNotes": {
        "type": "string",
        "maxLength": 500
      }
    },
    "required": [
      "intent",
      "items",
      "requestedResolution",
      "urgency"
    ]
  },
  "examples": [
    {
      "input": "Order A10492 arrived with a cracked ceramic mug. I opened the box but never used it. Can you send a replacement?",
      "output": {
        "intent": "warranty_claim",
        "orderId": "A10492",
        "items": [
          {
            "name": "ceramic mug",
            "quantity": 1,
            "reason": "damaged",
            "condition": "opened"
          }
        ],
        "requestedResolution": "replacement",
        "urgency": "normal",
        "customerNotes": "Cracked ceramic mug arrived in the box."
      }
    }
  ],
  "operations": {
    "edit": {
      "enabled": true,
      "return": "full_object",
      "rules": [
        "Start from currentJson.",
        "Apply only the user's requested change.",
        "Preserve all unspecified fields exactly.",
        "Return the complete updated JSON object."
      ],
      "examples": [
        {
          "currentJson": {
            "intent": "warranty_claim",
            "orderId": "A10492",
            "items": [
              {
                "name": "ceramic mug",
                "quantity": 1,
                "reason": "damaged",
                "condition": "opened"
              }
            ],
            "requestedResolution": "replacement",
            "urgency": "normal",
            "customerNotes": "Cracked ceramic mug arrived in the box."
          },
          "input": "actually I want a refund instead of a replacement",
          "output": {
            "intent": "refund",
            "orderId": "A10492",
            "items": [
              {
                "name": "ceramic mug",
                "quantity": 1,
                "reason": "damaged",
                "condition": "opened"
              }
            ],
            "requestedResolution": "refund",
            "urgency": "normal",
            "customerNotes": "Cracked ceramic mug arrived in the box."
          }
        }
      ]
    }
  }
}
